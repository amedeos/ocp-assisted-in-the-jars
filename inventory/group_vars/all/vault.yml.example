---
# Copy this file to vault.yml and fill in your values:
#   cp vault.yml.example vault.yml
#   # edit vault.yml with your credentials
#   make vault-encrypt
#
# vault.yml is in .gitignore and will NOT be committed.
#
# Create an activation key at:
#   https://console.redhat.com/insights/registration
#   https://console.redhat.com/insights/connector/activation-keys

secure_password: "CHANGE_ME"
rh_activation_key: "CHANGE_ME"
rh_org_id: "CHANGE_ME"
