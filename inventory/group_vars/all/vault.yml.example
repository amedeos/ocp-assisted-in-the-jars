---
# Copy this file to vault.yml and fill in your values:
#   cp vault.yml.example vault.yml
#   # edit vault.yml with your credentials
#   make vault-encrypt
#
# vault.yml is in .gitignore and will NOT be committed.
#
# Create an activation key at:
#   https://console.redhat.com/insights/registration
#   https://console.redhat.com/insights/connector/activation-keys

secure_password: "CHANGE_ME"

# Red Hat subscription credentials.
# Used by base_config (utility/ceph VMs) and by the hypervisor role
# when a hypervisor runs RHEL. On CentOS Stream the subscription step
# is skipped automatically (no entitlement needed), so these may stay
# unset if all your hosts are CentOS/Gentoo.
rh_activation_key: "CHANGE_ME"
rh_org_id: "CHANGE_ME"

# HTPasswd identity provider passwords.
# Generate with: openssl rand -hex 30
# Only htpasswd_admin_password is required; the others default to it.
htpasswd_admin_password: "CHANGE_ME"
# htpasswd_reader_password: "CHANGE_ME"
# htpasswd_test01_password: "CHANGE_ME"
# htpasswd_test02_password: "CHANGE_ME"
# htpasswd_test03_password: "CHANGE_ME"

# Pull secret for container registries (registry.redhat.io).
# Download from: https://console.redhat.com/openshift/install/pull-secret
# Save to: files/pull-secret.txt (gitignored, not in vault)
# Used by cephadm bootstrap to pull Ceph container images.
