---
# Multi-hypervisor inventory example
#
# This file defines hypervisors and VM placement. To override VM resources
# (CPU, RAM, disk) use a separate extra-vars file -- see lab-vars.yml.example.
#
# Setup:
#   1. cp hosts-multi.yml.example hosts-multi.yml
#   2. cp lab-vars.yml.example lab-vars.yml        (optional, for resource overrides)
#   3. Edit both files with your lab values
#   4. Deploy:
#        make deploy INVENTORY=inventory/hosts-multi.yml
#        make deploy INVENTORY=inventory/hosts-multi.yml CUSTOM_VARS=inventory/lab-vars.yml
#
# Why two files?
#   VM resources (vm_specs) are defined in group_vars/all/main.yml. Ansible
#   variable precedence means inventory vars cannot override group_vars.
#   CUSTOM_VARS uses -e @file which has the highest precedence.
#
# Both hosts-*.yml and *-vars.yml are in .gitignore and will NOT be committed.
#
# Requirements:
#   - SSH access (as root) from Ansible controller to each hypervisor
#   - The bridge specified in bridge_bm must exist on each hypervisor
#   - All bridges must share the same L2 domain (same VLAN / broadcast domain)
#   - RHEL golden image must be present on each hypervisor at image_dir
all:
  children:
    hypervisors:
      hosts:
        hypervisor01:
          ansible_user: root
          ansible_python_interpreter: /usr/bin/python3
          image_dir: /var/lib/libvirt/images
          bridge_bm: br-2003
        hypervisor02:
          ansible_user: root
          ansible_python_interpreter: /usr/bin/python3
          image_dir: /var/lib/libvirt/images
          bridge_bm: br-2003

    utility:
      hosts:
        utility:
          ansible_host: 192.168.203.254
          ansible_user: root
          ansible_ssh_private_key_file: files/.ssh/id_rsa
          ansible_ssh_common_args: "-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null"

    ceph:
      hosts:
        ceph:
          ansible_host: 192.168.203.252
          ansible_user: root
          ansible_ssh_private_key_file: files/.ssh/id_rsa
          ansible_ssh_common_args: "-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null"

  vars:
    # Override cluster_nodes to assign VMs to specific hypervisors.
    # The 'hypervisor' field must match a host name under 'hypervisors' above.
    cluster_nodes:
      - name: utility
        role: utility
        hypervisor: hypervisor02
        ip: 192.168.203.254
        ip_last_octet: 254
        mac: "52:54:00:00:33:FE"
      - name: ceph
        role: ceph
        hypervisor: hypervisor02
        ip: 192.168.203.252
        ip_last_octet: 252
        mac: "52:54:00:00:33:FC"
      - name: control-plane-0
        role: control-plane
        hypervisor: hypervisor01
        ip: 192.168.203.53
        ip_last_octet: 53
        mac: "52:54:00:00:33:00"
      - name: control-plane-1
        role: control-plane
        hypervisor: hypervisor01
        ip: 192.168.203.54
        ip_last_octet: 54
        mac: "52:54:00:00:33:01"
      - name: control-plane-2
        role: control-plane
        hypervisor: hypervisor02
        ip: 192.168.203.55
        ip_last_octet: 55
        mac: "52:54:00:00:33:02"
