apiVersion: v1
kind: ConfigMap
metadata:
  name: rook-ceph-external-cluster-details
  namespace: {{ odf_namespace }}
data:
  external_cluster_details: |
    [
      {
        "name": "rook-ceph-mon-endpoints",
        "kind": "ConfigMap",
        "data": {
          "data": "{{ ceph_mon_ip }}:6789",
          "mapping": "{}",
          "maxMonId": "0"
        }
      },
      {
        "name": "rook-ceph-mon",
        "kind": "Secret",
        "data": {
          "admin-secret": "admin-secret",
          "fsid": "{{ ceph_fsid }}",
          "mon-secret": "mon-secret"
        }
      },
      {
        "name": "rook-csi-rbd-provisioner",
        "kind": "Secret",
        "data": {
          "userID": "openshift",
          "userKey": "{{ ceph_key }}"
        }
      },
      {
        "name": "rook-csi-rbd-node",
        "kind": "Secret",
        "data": {
          "userID": "openshift",
          "userKey": "{{ ceph_key }}"
        }
      },
      {
        "name": "ceph-rbd",
        "kind": "StorageClass",
        "data": {
          "pool": "{{ ceph_config.pool_name }}"
        }
      },
      {
        "name": "monitoring-endpoint",
        "kind": "CephCluster",
        "data": {
          "MonitoringEndpoint": "{{ ceph_mon_ip }}",
          "MonitoringPort": "9283"
        }
      }
    ]
